        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .deposit-custom-label {
          margin-bottom: 6px !important;
          display: block !important;
        }
        
        .deposit-history-title {
          font-size: 11px !important;
          letter-spacing: 0.15em !important;
        }
        @media (min-width: 768px) {
          .deposit-history-title {
            font-size: 13px !important;
          }
        }
        @media (min-width: 1024px) {
          .deposit-history-title {
            font-size: 14px !important;
          }
        }
        
        input[type="text"].deposit-custom-input,
        input[type="number"].deposit-custom-input,
        input.deposit-custom-input {
          height: 32px !important;
          border-radius: 6px !important;
          font-size: 12px !important;
          padding-top: 0px !important;
          padding-bottom: 0px !important;
          padding-left: 10px !important;
          padding-right: 10px !important;
        }
        
        input.deposit-custom-input::placeholder {
          font-size: 11px !important;
          font-weight: normal !important;
          opacity: 0.65 !important;
        }
        
        .deposit-custom-file-btn {
          height: 32px !important;
          border-radius: 6px !important;
          font-size: 10px !important;
          padding-left: 12px !important;
          padding-right: 12px !important;
          padding-top: 0px !important;
          padding-bottom: 0px !important;
        }
        
        .deposit-custom-submit-btn {
          height: 34px !important;
          border-radius: 6px !important;
          font-size: 12px !important;
        }

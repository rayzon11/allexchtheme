        /* =========================================================
           DESKTOP (> 1024px)
           ========================================================= */
        @media (min-width: 1025px) {
          html, body {
            overflow-y: hidden !important;
            overflow-x: auto !important;
            height: 100vh !important;
            margin: 0 !important;
            padding: 0 !important;
          }
          #root {
            height: 100vh !important;
            overflow-y: hidden !important;
            overflow-x: auto !important;
          }
          .event-layout-scroll-wrapper {
            height: calc(100vh - 95px) !important;
            overflow-x: auto !important;
            overflow-y: hidden !important;
          }
        }

        /* =========================================================
           TABLET (769px - 1024px):
           Wrapper is fixed between mobile header (50px top) and
           bottom nav (60px bottom). Wrapper = viewport width + overflow-x:auto.
           Inner grid = min-width:1350px ŌåÆ creates real horizontal overflow inside wrapper.
           ========================================================= */
        @media (min-width: 769px) and (max-width: 1024px) {
          html, body, #root {
            overflow: hidden !important;
            height: 100vh !important;
            margin: 0 !important;
          }
          .event-layout-scroll-wrapper {
            position: fixed !important;
            top: 50px !important;
            bottom: 60px !important;
            left: 0 !important;
            right: 0 !important;
            width: 100vw !important;
            max-width: 100vw !important;
            min-width: auto !important;
            height: auto !important;
            margin: 0 !important;
            overflow-x: auto !important;
            overflow-y: hidden !important;
          }
          /* Inner grid keeps its 1350px min-width ŌåÆ overflows wrapper ŌåÆ scrollbar appears */
          .event-layout-row-container {
            height: 100% !important;
          }
        }

        /* =========================================================
           SCROLL WRAPPER BASE
           ========================================================= */
        .event-layout-scroll-wrapper {
          width: 100%;
          background-color: #f5f5f5;
          box-sizing: border-box;
        }

        /* Horizontal scrollbar ŌĆö always visible, styled */
        .event-layout-scroll-wrapper::-webkit-scrollbar {
          height: 8px !important;
          display: block !important;
        }
        .event-layout-scroll-wrapper::-webkit-scrollbar-track {
          background: #cbd5e1 !important;
        }
        .event-layout-scroll-wrapper::-webkit-scrollbar-thumb {
          background-color: #64748b !important;
          border-radius: 4px !important;
        }
        .event-layout-scroll-wrapper::-webkit-scrollbar-thumb:hover {
          background-color: #475569 !important;
        }

        /* =========================================================
           GRID CONTAINER (always 1350px min-width)
           ========================================================= */
        .event-layout-row-container {
          display: grid;
          grid-template-columns: 250px 1fr 450px;
          grid-gap: 10px;
          width: 100%;
          min-width: 1350px;
          background-color: #f5f5f5;
          align-items: stretch !important;
          overflow: visible !important;
          box-sizing: border-box !important;
        }

        @media (max-width: 1450px) {
          .event-layout-row-container {
            grid-template-columns: 240px 1fr 320px;
          }
        }

        /* Desktop: grid fills wrapper height */
        @media (min-width: 1025px) {
          .event-layout-row-container {
            height: 100% !important;
            max-width: calc(100% - 40px) !important;
            margin: 0 auto !important;
          }
        }

        /* =========================================================
           COLUMN STYLES
           ========================================================= */
        .event-layout-left-sidebar {
          background-color: #f7f7f7;
          border-right: 1px solid #ccc;
          overflow-y: auto !important;
          overflow-x: hidden !important;
          display: flex;
          flex-direction: column;
          height: 100% !important;
        }

        .event-layout-main-content {
          background-color: #fff;
          display: flex;
          flex-direction: column;
          height: 100% !important;
          overflow-y: auto !important;
          min-width: 0;
        }

        /* Inline vertical scrollbar for center content */
        .event-layout-main-content::-webkit-scrollbar {
          width: 6px !important;
        }
        .event-layout-main-content::-webkit-scrollbar-track {
          background: #f1f5f9 !important;
        }
        .event-layout-main-content::-webkit-scrollbar-thumb {
          background-color: #94a3b8 !important;
          border-radius: 3px !important;
        }

        .event-layout-right-sidebar {
          background-color: #fff;
          border-left: 1px solid #ccc;
          overflow-y: auto !important;
          overflow-x: hidden !important;
          display: flex;
          flex-direction: column;
          height: 100% !important;
        }

        /* =========================================================
           MOBILE (<= 768px): single column, normal scroll
           ========================================================= */
        @media (max-width: 768px) {
          .event-layout-scroll-wrapper {
            height: auto !important;
            overflow: visible !important;
          }
          .event-layout-row-container {
            grid-template-columns: 1fr !important;
            grid-gap: 0px !important;
            min-width: auto !important;
            height: auto !important;
            overflow: visible !important;
          }
          .event-layout-left-sidebar {
            display: none !important;
          }
          .event-layout-right-sidebar {
            display: none !important;
          }
          .event-layout-main-content {
            height: auto !important;
            overflow-y: visible !important;
          }
        }

            height: 32px;
            border-radius: 2px;
            overflow: hidden;
            background: #fff;
        }
        .odds-pair .box {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 12px;
            cursor: pointer;
            min-width: 45px;
        }
        .odds-pair .box.back { background-color: #72bbef; color: #000; }
        .odds-pair .box.lay { background-color: #faa9ba; color: #000; }
        
        .odds-pair.faded {
            opacity: 0.5;
            filter: grayscale(0.4);
        }
        
        .odds-grid-header {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 4px;
            width: 300px;
            text-align: center;
        }
        .odds-grid-header span {
            font-weight: 900;
            color: #444;
            font-size: 11px;
        }
        .col-odds-header {
            width: 310px;
        }
        .col-odds-wrap {
            width: 310px;
        }
        
        .suspended-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(255, 255, 255, 0.7);
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: center;
            pointer-events: none;
            border: 1px solid #efeff4;
        }
        .suspended-overlay span {
            color: #d0021b;
            font-weight: 900;
            font-size: 11px;
            padding: 2px 6px;
            background: #fff;
            border: 1px solid #d0021b;
            border-radius: 2px;
            letter-spacing: 0.5px;
        }

        @media (min-width: 981px) {
            .inplay-layout {
                padding-bottom: 0 !important;
                margin-bottom: 0 !important;
                min-height: calc(100vh - 120px) !important;
            }
            .subtabs {
                width: fit-content !important;
            }
            .subtab {
                flex: none !important;
                width: 150px !important;
            }
            .left-area {
                height: calc(100vh - 120px);
                overflow-y: auto;
                box-sizing: border-box;
                padding-bottom: 40px !important;
            }
            /* Hide scrollbar for a cleaner inline scroll look */
            .left-area::-webkit-scrollbar {
                width: 6px;
            }
            .left-area::-webkit-scrollbar-thumb {
                background-color: rgba(0,0,0,0.2);
                border-radius: 4px;
            }
            .right-area {
                position: sticky;
                top: 0;
                height: calc(100vh - 120px);
                overflow-y: auto;
                box-sizing: border-box;
                padding-bottom: 40px !important;
            }
            .right-area::-webkit-scrollbar {
                display: none;
            }
        }

        @media (max-width: 980px) {
            .right-area {
                display: none;
            }
            .left-area {
                width: 100% !important;
                margin-top: 10px; /* Added top gap */
            }
            .subtabs {
                width: 95% !important;
                max-width: 350px !important;
                margin: 0 auto 15px !important;
                border-radius: 6px !important;
            }
            .inplay-layout {
                min-height: calc(100vh - 50px);
            }
            /* Add horizontal scroll to the table container so odds don't break on tablet */
            .tab-content {
                overflow-x: auto;
            }
        }

        @media (max-width: 767px) {
            .col-odds-header, .col-odds-wrap {
                display: none;
            }
        }

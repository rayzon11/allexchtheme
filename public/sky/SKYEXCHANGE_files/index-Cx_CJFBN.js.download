        @keyframes pulse {
          0% { transform: scale(1); opacity: 1; }
          50% { transform: scale(1.2); opacity: 0.7; }
          100% { transform: scale(1); opacity: 1; }
        }

        /* Enforce professional, compact sizing for match-btn controls on tablet and mid-desktop views */
        .match-btn {
        
          height: 32px !important;
          display: flex !important;
          align-items: center !important;
          justify-content: center !important;
          list-style: none !important;
          padding: 0 !important;
          margin: 0 !important;
        }
        .match-btn li {
          position: relative !important;
          display: flex !important;
          align-items: center !important;
        }
        .match-btn li:first-of-type {
          margin-right: -1px !important;
        }
        .match-btn li:after {
          display: none !important;
        }
        .match-btn li:last-of-type:after {
          display: none !important;
        }
        .match-btn a {
          display: flex !important;
          align-items: center !important;
          justify-content: center !important;
          width: 100px !important;
          height: 25px !important;
          background-repeat: no-repeat !important;
          background-size: 100% 100% !important;
          color: #fff !important;
          font-size: 12px !important;
          font-weight: bold !important;
          box-sizing: border-box !important;
          background-position: center !important;
        }
        .match-btn a:before {
          content: "" !important;
          width: 14px !important;
          height: 14px !important;
          margin-right: 2px !important;
          background-position: center !important;
          background-repeat: no-repeat !important;
          background-size: contain !important;
        }
        .match-btn .btn-pin {
          padding-left: 12px !important;
          background-image: url('data:image/svg+xml,<svg width="100" height="25" viewBox="0 0 100 25" xmlns="http://www.w3.org/2000/svg"><path d="M100 0v25h-80.661c-4.413 0-9.506-3.243-11.377-7.248l-8.293-17.752h100z" fill="rgb(59,81,96)"/></svg>') !important;
        }
        .match-btn .btn-pin:before {
          background-image: url('data:image/svg+xml,<svg width="8" height="12" viewBox="0 0 8 12" xmlns="http://www.w3.org/2000/svg"><path d="M6.714 5.25c.857.321 1.286.812 1.286 1.473 0 .232-.036.384-.107.455-.071.071-.214.107-.429.107h-2.893l-.429 4.714h-.286l-.429-4.714h-2.893c-.214 0-.357-.04-.429-.121-.071-.08-.107-.228-.107-.442 0-.661.429-1.152 1.286-1.473l.143-.054c.262-.107.429-.277.5-.509l.643-3.161v-.134c0-.143-.119-.259-.357-.348l-.036-.027h-.036c-.286-.089-.429-.241-.429-.455 0-.25.048-.406.143-.469.095-.063.262-.094.5-.094h3.286c.238 0 .405.031.5.094.095.063.143.219.143.469 0 .214-.143.366-.429.455h-.036l-.036.027c-.238.089-.357.205-.357.348v.134l.643 3.161c.071.232.238.402.5.509l.143.054z" fill="rgb(255,255,255)"/></svg>') !important;
        }
        .match-btn .btn-pin.select {
          background-image: url('data:image/svg+xml,<svg width="100" height="25" viewBox="0 0 100 25" xmlns="http://www.w3.org/2000/svg"><path d="M100 0v25h-80.661c-4.413 0-9.506-3.243-11.377-7.248l-8.293-17.752h100z" fill="rgb(107,189,17)"/></svg>') !important;
        }
        .match-btn .btn-refresh {
          padding-right: 12px !important;
          background-image: url('data:image/svg+xml,<svg width="100" height="25" viewBox="0 0 100 25" xmlns="http://www.w3.org/2000/svg"><path d="M100 0l-8.293 17.752c-1.87 4.003-6.969 7.248-11.377 7.248h-80.661v-25z" fill="rgb(59,81,96)"/></svg>') !important;
